programa
 {
  funcao inicio()
   {
     real comprimento, largura, area, dobro

     escreva("digite comprimento do gramado: ")
     leia(comprimento)

     escreva("digite a largura do gramado: ")
     leia(largura) 

     area = comprimento * largura 
     dobro = area * 2 

     escreva("a area do gramado é: ", area, "\n")
     escreva("o dobro da area é: ", dobro)
     
   } 
}
